        <mxCell id="Brqm_ue2CW0-PKtNxzS9-12" value="&lt;h1 style=&quot;text-align: center;&quot;&gt;Traefik&lt;/h1&gt;&lt;div style=&quot;text-align: center;&quot;&gt;located in ./docker/traefik&lt;/div&gt;&lt;ul&gt;&lt;li&gt;Image: traefik:latest&lt;/li&gt;&lt;li&gt;Container Name: traefik&lt;/li&gt;&lt;li&gt;Restart: unless-stopped&lt;br&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Environment Variables&lt;/strong&gt;:&lt;br&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;CF_API_EMAIL=yourcloudflare@email.com&lt;/li&gt;&lt;li&gt;CF_DNS_API_TOKEN=YOURTOKEN&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;&lt;strong&gt;Volumes&lt;/strong&gt;:&lt;br&gt;&lt;/li&gt;&lt;ul&gt;&lt;li style=&quot;border-color: var(--border-color);&quot;&gt;/etc/localtime:/etc/localtime:ro&lt;/li&gt;&lt;li style=&quot;border-color: var(--border-color);&quot;&gt;/var/run/docker.sock:/var/run/docker.sock:ro&lt;/li&gt;&lt;li style=&quot;border-color: var(--border-color);&quot;&gt;./data-proxy/traefik.yml:/traefik.yml:ro&lt;/li&gt;&lt;li style=&quot;border-color: var(--border-color);&quot;&gt;./data-proxy/acme.json:/acme.json&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;&lt;b&gt;security_opt:&lt;br&gt;&lt;/b&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;no-new-privileges:true&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;Ports:&lt;/li&gt;&lt;ul&gt;&lt;li&gt;80:80&lt;/li&gt;&lt;li&gt;443:443&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;IPv4 Address: 172.16.0.2&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
